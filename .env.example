# Clawbot secrets — copy to .env, fill in, then `chmod 600 .env`.
# DO NOT commit .env. The .env.example is the only file checked in.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Dedicated Telegram bot (create via @BotFather; do NOT reuse the OpenClaw 'Claudbot' bot)
TELEGRAM_BOT_TOKEN=000000000:AAA...
TELEGRAM_CHAT_ID=1234567890

# Whop — forum posting requires a private Whop App installed on your whop.
# Company API keys do NOT work for forum posts. See README "Whop" section for setup.
# WHOP_API_KEY: the App API key (apik_...) from your private app's API Key tab.
# WHOP_APP_ID: the app id (app_...). Not currently sent in headers, but kept here
#   so future code can include X-App-Id if Whop ever requires it.
# WHOP_FORUM_ID: the forum's experience id (exp_...). Each forum is its own
#   experience; find this in the Whop dashboard under the forum's settings.
WHOP_API_KEY=apik_...
WHOP_APP_ID=app_...
WHOP_FORUM_ID=exp_...

# Supabase — service-role key bypasses RLS (server-only secret)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# Optional: GitHub PAT lifts unauth 60/hr API rate limit. Read-only public scope is enough.
GITHUB_TOKEN=

# Webhook public URL (set after you reverse-proxy or tunnel). Used only by setWebhook helper.
WEBHOOK_PUBLIC_URL=https://newcharterventures.com/clawbot/callback
